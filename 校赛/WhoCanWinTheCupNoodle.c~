#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <math.h>

using Int = long long;

Int k;

bool check(int x) {
    if(x * x * x + 3 * x + 1 >= k) return 1;
    else return 0;
}

int main() {
    scanf("%d", &k);
    Int low = 0, high = 1e18;
    while(low < high) {
	Int mid = (low + high) >> 1;
	if(check(mid)) low = mid;
	else high = mid - 1; 
    }
    printf("%d %d", low, high);
}
